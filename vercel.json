{
  "crons": [
    {
      "path": "/api/cron/pre-warm",
      "schedule": "0 */4 * * *"
    }
  ],
  "headers": [
    {
      "source": "/leaflet/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.ico",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
}